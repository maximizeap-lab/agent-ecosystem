# ============================================================
# Dashboard – Environment Variables Reference
# Copy this file to .env.local (dev) or inject via secrets manager (prod)
# NEVER commit real secrets to version control.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NODE_ENV=development                        # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Public-facing base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_ENVIRONMENT=development         # Shown in UI / used for feature flags
APP_PORT=3000

# ------------------------------------------------------------
# Authentication (NextAuth / Auth.js)
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-char-random-string  # openssl rand -base64 32

# OAuth Providers (add only what you use)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://dashboard:secret@localhost:5432/dashboard_db
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=secret
POSTGRES_DB=dashboard_db
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Redis (Cache / Sessions / BullMQ queues)
# ------------------------------------------------------------
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

# ------------------------------------------------------------
# AWS (used by S3, SES, Secrets Manager)
# ------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dashboard-assets-prod
AWS_SES_FROM_ADDRESS=noreply@yourdomain.com

# ------------------------------------------------------------
# External APIs / Integrations
# ------------------------------------------------------------
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Email (SMTP fallback)
# ------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ------------------------------------------------------------
# Nginx / Domain
# ------------------------------------------------------------
DOMAIN=localhost
